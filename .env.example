# 이 파일은 키 "이름"만 담는다. 실제 값은 .env (커밋 금지) 또는 Render 대시보드에 설정.

# DB 경로 (SQLite 파일)
DATABASE_URL=sqlite:///./localhub.db

# 챗봇 (OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=20

# CORS 허용 오리진 (콤마 구분) — 로컬 + Netlify 배포 도메인
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://<netlify-app>.netlify.app
